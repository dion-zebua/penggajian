	<subDataset name="Gaji Kotor" uuid="e1c5000e-b7ce-4add-bbbe-66fe408fa6ff">
		<queryString>
			<![CDATA[SELECT g.id,
       g.karyawan_id,
       k.nama,
       g.bulan,
       g.tahun,
       g.gaji_pokok,

       g.total
FROM gaji_kotor g
JOIN karyawan k ON g.karyawan_id = k.id
ORDER BY g.tahun DESC,
FIELD(g.bulan,
'Desember','November','Oktober','September','Agustus','Juli',
'Juni','Mei','April','Maret','Februari','Januari');]]>
		</queryString>
		<field name="id" class="java.math.BigInteger">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="karyawan_id" class="java.math.BigInteger">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="nama" class="java.lang.String">
